# Template for the per-environment .env files (.env.dev / .env.test / .env.prod).
# Copy and adjust. Never commit real secrets.

# --- OpenMRS core image tag used as the runtime base ---
# Pick a tag matching the openmrs.version in pom.xml where possible.
OPENMRS_CORE_TAG=nightly

# --- Database connection (consumed by BOTH the openmrs app and the db container) ---
OMRS_DB_HOSTNAME=db          # service name on the compose network; leave as "db"
OMRS_DB_PORT=3306            # container-internal port; leave as 3306
OMRS_DB_NAME=openmrs
OMRS_DB_USERNAME=openmrs
OMRS_DB_PASSWORD=change_me
OMRS_DB_ROOT_PASSWORD=change_me_root

# --- Schema lifecycle ---
OMRS_DB_AUTO_UPDATE=true     # run liquibase updates on startup
OMRS_CREATE_TABLES=true      # create schema on first run

# --- App settings ---
OMRS_MODULE_WEB_ADMIN=true
OMRS_ADMIN_USER_PASSWORD=Admin123

# --- Host port mappings ---
OMRS_WEB_PORT=8080           # host port -> openmrs 8080
OMRS_DB_HOST_PORT=3306       # host port -> db 3306 (dev/test only; prod unpublished)
